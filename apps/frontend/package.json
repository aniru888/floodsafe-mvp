        "cmdk": "^1.1.1",
        "driver.js": "^1.4.0",
        "embla-carousel-react": "^8.6.0",
        "exifreader": "^4.33.1",
        "firebase": "^10.7.0",
        "input-otp": "^1.4.2",
        "lucide-react": "^0.290.0",
        "maplibre-gl": "^3.6.0",
        "next-themes": "^0.4.6",
        "pmtiles": "^2.11.0",
        "react": "^18.2.0",
        "react-day-picker": "^9.11.1",
        "react-dom": "^18.2.0",
