{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "npx @tailwindcss/cli -i src/styles/globals.css -o src/index.css && vite",
        "dev:css": "npx @tailwindcss/cli -i src/styles/globals.css -o src/index.css --watch",
        "build:css": "npx @tailwindcss/cli -i src/styles/globals.css -o src/index.css --minify",
        "build": "npm run build:css && tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 50",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:run": "vitest run",
        "screenshot": "npx tsx scripts/screenshot.ts",
        "screenshot:baseline": "npx tsx scripts/ui-overhaul-visual-test.ts"
    },
    "dependencies": {
        "@mcp-b/global": "^1.5.0",
        "@mcp-b/react-webmcp": "^1.1.1",
